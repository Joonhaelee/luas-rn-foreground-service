<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Android 13+ notification permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Android 14+ foreground service type permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application>
        <!-- Main foreground service with Android 14+ service types -->
        <service android:name=".ForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync|location|mediaPlayback" />

        <!-- Headless task service -->
        <service android:name=".ForegroundServiceHeadlessTask"
            android:exported="false" />

        <!-- Notification event receiver for button clicks -->
        <receiver android:name=".NotificationEventReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="rnforegroundservice.NOTIFICATION_BUTTON1" />
                <action android:name="rnforegroundservice.NOTIFICATION_BUTTON2" />
                <action android:name="rnforegroundservice.NOTIFICATION_CONTENT" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
